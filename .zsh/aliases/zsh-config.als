### alias-configuration.als ###

alias al-update='source ~/.zsh/aliases/load-aliases'
alias al-edit-config='$EDITOR ~/.aliases/alias-configuration.als'
alias al-search='alias | dmenu -b -l 10 -i -p "Search for: "'

alias ed-zsh='$EDITOR ~/.zshrc'
alias ed-bash='$EDITOR ~/.bashrc'

alias upd-zshrc='source ~/.zshrc'
alias upd-bashrc='source ~/.bashrc'
